{
  "name": "@betterpkg/fetchkit",
  "version": "1.0.0",
  "description": "A lightweight, zero-dependency, axios-like HTTP client built on top of the Fetch API.",
  "keywords": [
    "axios",
    "client",
    "fetch",
    "http"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "release:check": "npm run lint && npm run check && npm test -- --coverage && npm run build && npm pack --dry-run",
    "test": "vitest run"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@vitest/coverage-v8": "^4.1.3",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "publint": "^0.3.18",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
